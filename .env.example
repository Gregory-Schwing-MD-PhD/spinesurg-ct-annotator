# Copy to .env and fill in. Never commit .env.

# Hugging Face
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SOURCE_DATASET=greg-schwing/CTSpinoPelvic1K
TARGET_DATASET=greg-schwing/CTSpinoPelvic1K-annotations

# OAuth (HF Spaces injects these automatically in production;
# for local dev, register an OAuth app at https://huggingface.co/settings/connected-applications)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Session signing key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=

# Set to true only for local development (allows insecure cookies)
DEV_MODE=true
